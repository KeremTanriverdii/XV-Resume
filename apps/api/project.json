{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/api/ResumeXCreator.Api",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet build apps/api/ResumeXCreator.slnx"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet watch run --project apps/api/ResumeXCreator.Api/ResumeXCreator.Api.csproj"
      }
    }
  }
}
